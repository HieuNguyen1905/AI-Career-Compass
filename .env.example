# Backend
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
JWT_SECRET="replace-with-a-long-random-secret"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
DEFAULT_MODEL="gpt-4o-mini"
OPENAI_WEB_SEARCH_ENABLED="true"
OPENAI_WEB_SEARCH_MODEL="gpt-5-search-api"
OPENAI_TEMPERATURE="0.4"
OPENAI_MAX_TOKENS="1200"
CAREER_SCOPE_MODE="hybrid"
OPENAI_SCOPE_MODEL="gpt-4o"
OPENAI_SCOPE_CONFIDENCE_THRESHOLD="0.85"
CAREER_EXPLANATION_MODEL="gpt-4o-mini"
CAREER_EXPLANATION_TIMEOUT="30"
CAREER_EXPLANATION_PROMPT_VERSION="v2"
CAREER_EXPLANATION_PRECOMPUTE_LIMIT="5"
LOG_LEVEL="INFO"
DB_POOL_MIN_SIZE="0"
DB_POOL_MAX_SIZE="5"
DB_POOL_TIMEOUT="10"
DB_CONNECT_TIMEOUT="10"

# Frontend
API_BASE_URL="https://your-backend.example.com"
NEXT_PUBLIC_API_URL="https://your-backend.example.com"
API_TIMEOUT_MS="30000"
AUTH_TIMEOUT_MS="20000"
CAREER_MATCH_TIMEOUT_MS="60000"
ASSESSMENT_SUBMIT_TIMEOUT_MS="60000"
SESSION_SECRET="replace-with-a-long-random-secret"

# Optional Supabase public config
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
